{
  "expo": {
    "name": "Invader Hunter",
    "slug": "frontend",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/InvaderHunterIcon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "icon": "./assets/images/InvaderHunterIcon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/InvaderHunterIcon.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.invaderhunter.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Invader Hunter to access your photos.",
          "cameraPermission": "Allow Invader Hunter to take photos of invaders."
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-tracking-transparency",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/InvaderHunterIcon.png",
          "color": "#208AEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08070d4b-8954-4319-b63f-4995780b93be"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/08070d4b-8954-4319-b63f-4995780b93be"
    }
  }
}
